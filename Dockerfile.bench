FROM python:3.12-slim

ARG DEBIAN_FRONTEND=noninteractive
ARG TARGETPLATFORM
ARG GHIDRA_URL
ARG GHIDRA_SHA256

ENV GHIDRA_INSTALL_DIR=/opt/ghidra \
    JAVA_HOME=/opt/java/openjdk \
    PATH=/opt/java/openjdk/bin:/root/.local/bin:${PATH} \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/opt/local_llm_bench \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        nodejs \
        npm \
        openjdk-21-jdk-headless \
        unzip \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/java \
    && java_bin="$(readlink -f "$(command -v java)")" \
    && java_home="$(dirname "$(dirname "${java_bin}")")" \
    && ln -s "${java_home}" /opt/java/openjdk

RUN curl -LsSf https://astral.sh/uv/install.sh | sh

WORKDIR /opt/local_llm_bench

COPY requirements.txt /opt/local_llm_bench/requirements.txt
RUN pip install --upgrade pip \
    && pip install -r /opt/local_llm_bench/requirements.txt

COPY . /opt/local_llm_bench

RUN test -n "${GHIDRA_URL}" \
    && curl -fsSL "${GHIDRA_URL}" -o /tmp/ghidra.zip \
    && if [ -n "${GHIDRA_SHA256}" ]; then \
        echo "${GHIDRA_SHA256}  /tmp/ghidra.zip" | sha256sum -c -; \
    fi \
    && unzip -q /tmp/ghidra.zip -d /opt \
    && rm -f /tmp/ghidra.zip \
    && ghidra_dir="$(find /opt -maxdepth 1 -type d -name 'ghidra_*_PUBLIC*' | head -n 1)" \
    && test -n "${ghidra_dir}" \
    && ln -s "${ghidra_dir}" "${GHIDRA_INSTALL_DIR}" \
    && expected_decompiler="" \
    && case "${TARGETPLATFORM}" in \
        "linux/amd64") expected_decompiler="${GHIDRA_INSTALL_DIR}/Ghidra/Features/Decompiler/os/linux_x86_64/decompile" ;; \
        "linux/arm64") expected_decompiler="${GHIDRA_INSTALL_DIR}/Ghidra/Features/Decompiler/os/linux_arm_64/decompile" ;; \
      esac \
    && if [ -n "${expected_decompiler}" ] && [ ! -f "${expected_decompiler}" ]; then \
        echo "Error: expected Ghidra native decompiler is missing for ${TARGETPLATFORM}: ${expected_decompiler}" >&2; \
        exit 1; \
      fi

CMD ["python", "-m", "local_llm_bench.docker_task.container_worker", "--help"]
